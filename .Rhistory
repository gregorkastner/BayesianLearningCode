exptheta3 <- exp(theta[3])
denom <- 1 + exptheta2 + exptheta3
alpha1 <- exptheta2 / denom
gamma1  <- exptheta3 / denom
c(alpha0, alpha1, gamma1)
}
# Chunk 36
loglik <- function(y, theta) {
pars <- unrestricted2restricted(theta)
sigma2 <- rep(NA_real_, length(y))
# Initialize at unconditional variance
sigma2[1] <- pars[1] / (1 - pars[2] - pars[3])
for (i in 2:length(y)) {
sigma2[i] <- pars[1] + pars[2] * y[i - 1]^2 + pars[3] * sigma2[i - 1]
}
loglik <- -0.5 * log(2 * pi) * length(y) - sum(log(sigma2) + y^2 / sigma2)
# To return sigma2 as a by-product, we "attach" it to the loglik value
attr(loglik, "sigma2") <- sigma2
loglik
}
logprior <- function(theta, priormeans = rep(0, 3), priorsds = rep(10, 3)) {
dnorm(theta[1], priormeans[1], priorsds[1], log = TRUE) +
dnorm(theta[2], priormeans[2], priorsds[2], log = TRUE) +
dnorm(theta[3], priormeans[3], priorsds[3], log = TRUE)
}
# Chunk 37
sampler <- function(y, M = 20000L, nburn = 2000L, propsds = rep(0.15, 3)) {
# Allocate storage
thetas <- matrix(NA_real_, M, 3)
sigma2s <- matrix(NA_real_, M, length(y))
# Starting values
theta <- rep(0, 3)
currentlogpost <- loglik(y, theta) + logprior(theta)
naccepts <- 0L
for (m in seq_len(nburn + M)) {
prop <- rnorm(3, theta, propsds)
proplogpost <- loglik(y, prop) + logprior(prop)
logR <- proplogpost - currentlogpost
# Accept / reject
if (log(runif(1)) < logR) {
theta <- prop
currentlogpost <- proplogpost
if (m > nburn) naccepts <- naccepts + 1L
}
# Store
if (m > nburn) {
thetas[m - nburn, ] <- theta
sigma2s[m - nburn, ] <- attr(currentlogpost, "sigma2")
}
}
# Transform back to the usual parameterization
paras <- t(apply(thetas, 1, unrestricted2restricted))
colnames(paras) <- c("alpha0", "alpha1", "gamma1")
ret <- list(para = as.data.frame(paras), sigma2 = sigma2s,
theta = as.data.frame(thetas), y = y,
ndraws = M, nburn = nburn, acceptrate = naccepts / ndraws)
ret
}
# Chunk 38
data("exrates", package = "stochvol")
y <- 100 * diff(log(exrates$USD / exrates$CHF))
# Run the sampler
